# Direct Bright Data Web Unlocker API
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1
BRIGHTDATA_API_KEY=

# Bright Data Browser API (optional final fallback)
BRIGHTDATA_BROWSER_USERNAME=
BRIGHTDATA_BROWSER_PASSWORD=
BRIGHTDATA_BROWSER_HOST=brd.superproxy.io
BRIGHTDATA_BROWSER_PORT=9222

# Runtime defaults
SCRAPER_CONCURRENCY=40
SCRAPER_PER_SITE_CONCURRENCY=3
SCRAPER_TIMEOUT_SECONDS=15
SCRAPER_MAX_PAGES=6
SCRAPER_DEFAULT_PHONE_REGION=US
SCRAPER_USE_WEB_UNLOCKER=true
SCRAPER_USE_BROWSER=true
SCRAPER_RESPECT_ROBOTS_TXT=true

# Optional website-finder search providers.
# The finder works without these by using free public sources plus page
# verification. Add keys only if you have free/trial quota available.
# Best free upgrade: point this at your own or trusted SearXNG instance with
# JSON search output enabled.
SEARXNG_BASE_URL=
# Legacy Google option for existing accounts only.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=
SEARCHAPI_API_KEY=

# Optional Google Sheets export
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_TAB=Scraper Results
